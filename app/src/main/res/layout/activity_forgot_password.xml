<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFAA00"> <LinearLayout
    android:id="@+id/headerContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="60dp"
    android:translationY="-100dp"
    android:alpha="0"> <TextView
    android:id="@+id/headerTitle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Reset Password"
    android:textSize="32sp"
    android:textStyle="bold"
    android:textColor="#237227"
    android:textAlignment="center" />

    <TextView
        android:id="@+id/headerSub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Masukkan emailmu untuk menerima link pemulihan"
        android:textSize="14sp"
        android:textColor="#237227"
        android:textAlignment="center"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="32dp"/>
</LinearLayout>

    <LinearLayout
        android:id="@+id/forgotSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_login_sheet"
        android:orientation="vertical"
        android:padding="32dp"
        android:translationY="500dp"
        android:alpha="0">

        <EditText
            android:id="@+id/etResetEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Email Address"
            android:textColorHint="#237227"
            android:textColor="#237227"
            android:paddingStart="16dp"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnSendReset"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Send Reset Link"
            android:textColor="#237227"
            android:textStyle="bold"
            android:backgroundTint="#FFAA00" />

        <TextView
            android:id="@+id/tvBackToLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kembali ke Login"
            android:textStyle="bold"
            android:textColor="#FFAA00"
            android:textAlignment="center"
            android:layout_marginTop="24dp"/>

    </LinearLayout>
</RelativeLayout>