<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFAA00"> <TextView
    android:id="@+id/splashText"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_centerInParent="true"
    android:text="SafeWalk"
    android:textColor="#237227"
    android:textSize="48sp"
    android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/loginSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_login_sheet"
        android:orientation="vertical"
        android:padding="24dp"
        android:translationY="1000dp"> <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SafeWalk"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFD786"
        android:textAlignment="center"
        android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Satu Sentuhan untuk Keselamatan"
            android:textSize="14sp"
            android:textColor="#FFD786"
            android:textAlignment="center"
            android:layout_marginBottom="32dp"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Email"
            android:textColorHint="#237227"
            android:textColor="#237227"
            android:paddingStart="16dp"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Password"
            android:textColorHint="#237227"
            android:textColor="#237227"
            android:paddingStart="16dp"
            android:inputType="textPassword"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Forgot password?"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFD786"
            android:textAlignment="viewEnd"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Login"
            android:textColor="#237227"
            android:textStyle="bold"
            android:backgroundTint="#FFAA00" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don't have an account? "
                android:textColor="#FFD786"/>

            <TextView
                android:id="@+id/tvSignUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign up"
                android:textStyle="bold"
                android:textColor="#FFAA00"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>